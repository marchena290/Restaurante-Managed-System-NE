@model RestauranteApp.Models.M_Cliente

@{
    ViewBag.Title = "EliminaClientes";
}

<h2>Elimina Cliente</h2>
|
<h3>Está seguro que desea eliminar el cliente seleccionado?</h3>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.IdCliente)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.IdCliente)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Nombre)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Nombre)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Apellido)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Apellido)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Telefono)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Telefono)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Correo)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Correo)
        </dd>

    </dl>

    @using (Html.BeginForm("Acciones", "Clientes", FormMethod.Post, new { enctype = "multipart/formdata", @id = "frmClientes" }))
    {
        @Html.AntiForgeryToken()

        @Html.HiddenFor(w => w.IdCliente)
        @Html.HiddenFor(w => w.Nombre)
        @Html.HiddenFor(w => w.Apellido)
        @Html.HiddenFor(w => w.Telefono)
        @Html.HiddenFor(w => w.Correo)

        <div class="form-actions no-color">
            <button type="submit" id="btnEliminar" name="submitButton" value="Eliminar" class="btn btn-danger" title="Agregar" data-toggle="tooltip" data-container="body"
                    data-placement="right">
                Eliminar
            </button> |
            @Html.ActionLink("Regresar", "ListaClientes", null, new {@class = "btn btn-primary btn-sm" })
        </div>
    }
</div>
