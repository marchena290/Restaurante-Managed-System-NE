@{
    ViewBag.Title = "Acerca del Sistema Fénix";
}

<div class="jumbotron jumbotron-fondo">
    <h1>Sistema de Gestión Restaurante Fénix</h1>
    <p class="lead">Administración integral para tu restaurante</p>
</div>

<div class="container">
    <div class="center-box">
        <h2 class="text-center">Uso del Sistema</h2>
        <div class="list-group">
            <div class="list-group-item">
                <h4 class="list-group-item-heading">Clientes</h4>
                <p class="list-group-item-text">
                    Gestión completa de la base de clientes. Registra información,
                    preferencias y seguimiento de cada cliente.
                </p>
            </div>
            <div class="list-group-item">
                <h4 class="list-group-item-heading">Menús</h4>
                <p class="list-group-item-text">
                    Administra tu carta de manera sencilla. Actualiza,
                    agrega o elimina platillos con facilidad.
                </p>
            </div>
            <div class="list-group-item">
                <h4 class="list-group-item-heading">Mesas</h4>
                <p class="list-group-item-text">
                    Control total de la distribución de mesas.
                    Visualiza disponibilidad y estado en tiempo real.
                </p>
            </div>
            <div class="list-group-item">
                <h4 class="list-group-item-heading">Reservaciones</h4>
                <p class="list-group-item-text">
                    Gestiona reservaciones de manera eficiente.
                    Programa, modifica y realiza seguimiento de cada reserva.
                </p>
            </div>
        </div>
    </div>
</div>