@model IEnumerable<RestauranteApp.Models.M_Reservacion>
@{
    ViewBag.Title = "ListaReservaciones";
}

<h2>Lista de Reservaciones</h2>

<p>
    @Html.ActionLink("Create Reservación", "AgregaReservacion")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.IdReservaciones)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.IdCliente)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.IdMesa)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.IdMenu)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Cantidad)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FechaReservacion)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.IdReservaciones)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdCliente)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdMesa)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdMenu)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Cantidad)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FechaReservacion)
            </td>
            <td>
                @Html.ActionLink("Modificar", "ModificaReservaciones", new {  id=item.IdReservaciones}, new {@class = "btn btn-success btn-sm" }) |
                @Html.ActionLink("Eliminar", "EliminaReservaciones", new { id = item.IdReservaciones}, new {@class = "btn btn-danger btn-sm" })
            </td>
        </tr>
    }

</table>
